  s.addText("QISKIT IMPLEMENTATION — WHAT RUNS ON THE CPU (CLASSICAL SIMULATION)", { x:0.4, y:0, w:9.2, h:0.55, fontSize:14, color:C.white, bold:true, valign:"middle", margin:0 });

  // Left: what Qiskit solves
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.65, w:3.2, h:4.75, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("What Qiskit solves:", { x:0.42, y:0.68, w:2.96, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  const qiskitSolves = [
    ["Eq 1+2","Rate + FBL penalty calculation"],
    ["Eq 3","Utility function (PF weights)"],
    ["Eq 4","Constraint checking (oracle)"],
    ["Eq 5","Amplitude state vector"],
    ["Eq 6","Oracle (auto-built)"],
    ["Eq 7","Diffusion operator"],
    ["Eq 8","Iteration count"],
    ["—","ArgMax → best schedule"],
  ];
  qiskitSolves.forEach(([eq, desc], i) => {
    s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.05+i*0.46, w:2.96, h:0.4, fill:{color:C.white}, line:{color:C.border} });
    s.addText(eq, { x:0.47, y:1.05+i*0.46, w:0.72, h:0.4, fontSize:9.5, color:C.teal, bold:true, fontFace:"Courier New", valign:"middle", margin:0 });
    s.addText(desc, { x:1.22, y:1.05+i*0.46, w:2.1, h:0.4, fontSize:9.5, color:C.text, valign:"middle", margin:0 });
  });

  // Right: code
  s.addShape(pres.shapes.RECTANGLE, { x:3.65, y:0.65, w:6.05, h:4.75, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("# qiskit_scheduler.py — Complete baseline (use qiskit_algorithms, Qiskit ≥ 1.0)", { x:3.75, y:0.65, w:5.85, h:0.26, fontSize:8, color:"6A9955", fontFace:"Courier New", margin:0 });
  const code = [
    ["import numpy as np", C.white],
    ["from qiskit import QuantumCircuit", C.white],
    ["from qiskit_algorithms import Grover, AmplificationProblem", C.white],
    ["from qiskit.primitives import StatevectorSampler", C.white],
    ["", C.white],
    ["N, K = 8, 4   # 8 users, schedule 4 per slot", C.white],
    ["np.random.seed(None)   # NOT seed=42 — use multiple seeds!", "6A9955"],
    ["sinr = 10**(np.random.uniform(-5,20,N)/10)", C.white],
    ["weights = np.random.uniform(0.5, 1.5, N)", C.white],
    ["", C.white],
    ["# Threshold: greedy estimate (NOT O(2^N) enumeration)", "6A9955"],
    ["greedy_sorted = np.argsort(weights*np.log2(1+sinr))[::-1][:K]", C.white],
    ["thr = sum(weights[i]*np.log2(1+sinr[i]) for i in greedy_sorted)*0.9", C.white],
    ["", C.white],
    ["def utility(bs):", C.white],
    ["    sel=[i for i,b in enumerate(bs) if b=='1']", C.white],
    ["    if len(sel)!=K: return 0", C.white],
    ["    return sum(weights[i]*np.log2(1+sinr[i]) for i in sel)", C.white],
    ["", C.white],
    ["def is_good(bs):   # Oracle — Eq 6", C.white],
    ["    return utility(bs) >= thr", C.white],
    ["", C.white],
    ["problem = AmplificationProblem(is_good_state=is_good)", C.white],
    ["grover  = Grover(sampler=StatevectorSampler())", C.white],
    ["result  = grover.amplify(problem)", C.white],
    ["print('Best schedule:', result.top_measurement)", C.white],
    ["print('Utility:', utility(result.top_measurement))", C.white],
  ];
  code.forEach(([line, col], i) => {
    s.addText(line, { x:3.75, y:0.93+i*0.165, w:5.85, h:0.165, fontSize:8.2, color:col, fontFace:"Courier New", margin:0 });
  });

  // Role label
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:5.42, w:9.4, h:0.28, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText("Role of Qiskit: algorithmic correctness baseline — validates FPGA output; NOT the speed contribution", {
    x:0.3, y:5.42, w:9.4, h:0.28, fontSize:10, color:C.teal, bold:true, align:"center", valign:"middle", margin:0
  });
}

