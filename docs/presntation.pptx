{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("6G URLLC REQUIREMENTS & USE CASES", { x:0.4, y:0, w:9.2, h:0.55, fontSize:16, color:C.white, bold:true, valign:"middle", margin:0 });

  // Stats row
  const stats = [
    ["< 0.1 ms", "Air interface latency", C.teal],
    ["< 500 μs", "User-plane processing\n← OUR TARGET", C.green],
    ["99.9999%", "Reliability\n(10⁻⁶ error rate)", C.navy],
