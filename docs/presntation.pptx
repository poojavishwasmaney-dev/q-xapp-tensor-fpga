  // Comparison table
  const rows = [
    [{text:"Method", options:{bold:true, color:C.white, fill:{color:C.navy}}}, {text:"Latency (N=32)", options:{bold:true, color:C.white, fill:{color:C.navy}}}, {text:"Why it fails", options:{bold:true, color:C.white, fill:{color:C.navy}}}, {text:"Status", options:{bold:true, color:C.white, fill:{color:C.navy}}}],
    ["Exhaustive search", ">1 hour", "Checks all 2^32 = 4.3B combinations", {text:"✗ Impossible", options:{color:C.red, bold:true}}],
    ["Greedy algorithm", "0.2 ms ✓", "15–30% suboptimal — misses better schedules", {text:"△ Partial", options:{color:C.amber, bold:true}}],
    ["Deep RL (DQN inference)", "<1 ms on GPU", "Needs GPU hardware; hard to deploy at edge", {text:"△ Partial", options:{color:C.amber, bold:true}}],
    ["Qiskit on CPU", "10–100 ms", "Python simulation overhead violates URLLC", {text:"✗ Too slow", options:{color:C.red, bold:true}}],
    [{text:"FPGA Oracle-Diffusion (proposed)", options:{bold:true, color:C.teal}}, {text:"Target <500 μs", options:{bold:true, color:C.teal}}, {text:"Hardware parallelism, fixed-point arithmetic", options:{bold:true, color:C.teal}}, {text:"✓ Target", options:{color:C.green, bold:true}}],
  ];
  s.addTable(rows, {
    x:0.3, y:2.2, w:9.4, h:2.65,
    border:{pt:0.5, color:C.border},
    fill:{color:C.white},
    colW:[2.8, 1.9, 3.2, 1.5],
    fontFace:"Calibri", fontSize:11,
    rowH:0.44,
  });

  // Note box
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:5.0, w:9.4, h:0.42, fill:{color:C.goldLt}, line:{color:C.gold} });
  s.addText("Note: DQN latency above is inference-only. Source: Hu et al. IEEE TWC 2023. URLLC target: 3GPP TR 38.824 / ITU-R M.2160.", {
    x:0.42, y:5.0, w:9.2, h:0.42, fontSize:9.5, color:C.amber, valign:"middle", margin:0
  });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 4 — 6G URLLC REQUIREMENTS
