const pptxgen = require("pptxgenjs");

const pres = new pptxgen();
pres.layout = 'LAYOUT_16x9';
pres.title = 'FPGA-Accelerated Oracle-Diffusion Scheduling for 6G URLLC';

// ─── PALETTE ───
const C = {
  navy:    "0B1F3A",
  teal:    "0A7EA4",
  tealLt:  "E8F4F8",
  tealMid: "1A9CC4",
  white:   "FFFFFF",
  offWht:  "F7F9FC",
  slate:   "4A6274",
  slateXlt:"EFF3F6",
  gold:    "E8A020",
  goldLt:  "FEF3E2",
  green:   "1A7A4A",
  greenLt: "E6F4EC",
  red:     "B83232",
  redLt:   "FDEAEA",
  amber:   "B86A00",
  amberLt: "FFF0D6",
  text:    "1A2A3A",
  muted:   "5A6E7E",
  border:  "CBD8E4",
  codeBg:  "0D1B2A",
  codeGr:  "4EC9B0",
};

const makeShadow = () => ({ type:"outer", blur:8, offset:3, angle:135, color:"000000", opacity:0.10 });
const makeCardShadow = () => ({ type:"outer", blur:5, offset:2, angle:135, color:"000000", opacity:0.07 });

// ═══════════════════════════════════════════════════════════
// SLIDE 1 — TITLE
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.navy };

  // Left accent bar
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:0.25, h:5.625, fill:{color:C.teal}, line:{color:C.teal} });

  // Teal top band
  s.addShape(pres.shapes.RECTANGLE, { x:0.25, y:0, w:9.75, h:0.06, fill:{color:C.teal}, line:{color:C.teal} });

  // "MSc Project Proposal" badge
  s.addShape(pres.shapes.ROUNDED_RECTANGLE, { x:0.55, y:0.5, w:2.4, h:0.38, fill:{color:C.tealMid}, line:{color:C.tealMid}, rectRadius:0.06 });
  s.addText("MSc PROJECT PROPOSAL", { x:0.55, y:0.5, w:2.4, h:0.38, fontSize:9, color:C.white, bold:true, align:"center", valign:"middle", charSpacing:2 });

  // Main title
  s.addText("FPGA-Accelerated", { x:0.55, y:1.1, w:8.8, h:0.75, fontSize:42, color:C.white, bold:true, fontFace:"Calibri", margin:0 });
  s.addText("Oracle-Diffusion User Scheduling", { x:0.55, y:1.82, w:8.8, h:0.75, fontSize:36, color:C.tealMid, bold:true, fontFace:"Calibri", margin:0 });
  s.addText("for 6G URLLC", { x:0.55, y:2.54, w:8.8, h:0.6, fontSize:36, color:C.white, bold:false, fontFace:"Calibri", margin:0 });

  // Divider
  s.addShape(pres.shapes.LINE, { x:0.55, y:3.28, w:8.8, h:0, line:{color:C.teal, width:1.5} });

  // Sub-labels
  s.addText([
    { text:"Platform:  ", options:{color:C.muted+"AA", bold:false} },
    { text:"AMD Kria KV260 FPGA + Qiskit (Python)", options:{color:C.white, bold:true} },
  ], { x:0.55, y:3.42, w:8.8, h:0.35, fontSize:13, fontFace:"Calibri", margin:0 });

  s.addText([
    { text:"Algorithm:  ", options:{color:C.muted+"AA", bold:false} },
    { text:"Grover-Inspired Oracle-Diffusion Pattern (Classical Simulation)", options:{color:C.white, bold:true} },
  ], { x:0.55, y:3.78, w:8.8, h:0.35, fontSize:13, fontFace:"Calibri", margin:0 });

  s.addText([
    { text:"Domain:  ", options:{color:C.muted+"AA", bold:false} },
    { text:"5G/6G Ultra-Reliable Low-Latency Communication (URLLC)", options:{color:C.white, bold:true} },
  ], { x:0.55, y:4.14, w:8.8, h:0.35, fontSize:13, fontFace:"Calibri", margin:0 });

  s.addText("Candidate: [Your Name]  |  Supervisor: [Supervisor Name]  |  [Date]", {
    x:0.55, y:5.1, w:8.8, h:0.3, fontSize:10, color:C.muted+"BB", align:"left", margin:0
  });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 2 — THE CRITICAL CLARIFICATION
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("WHAT THIS PROJECT IS — AND IS NOT", { x:0.4, y:0, w:9.2, h:0.55, fontSize:16, color:C.white, bold:true, valign:"middle", margin:0 });

  // Left: IS NOT
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.75, w:4.3, h:0.4, fill:{color:C.redLt}, line:{color:C.red} });
  s.addText("✗  What this project is NOT", { x:0.3, y:0.75, w:4.3, h:0.4, fontSize:12, color:C.red, bold:true, valign:"middle", margin:8 });

  const notItems = [
    "Running on real quantum hardware (IBM/Google qubits)",
    "Achieving O(√N) quantum speedup — that only exists on real quantum hardware",
    "Quantum computing in any physical sense",
    "Qiskit on CPU is a classical matrix simulation — NOT quantum",
  ];
  notItems.forEach((txt, i) => {
    s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:1.22+i*0.62, w:4.3, h:0.52, fill:{color:C.redLt}, line:{color:C.border}, shadow:makeCardShadow() });
    s.addText(txt, { x:0.42, y:1.22+i*0.62, w:4.1, h:0.52, fontSize:11, color:C.red, valign:"middle", margin:0 });
  });

  // Right: IS
  s.addShape(pres.shapes.RECTANGLE, { x:5.1, y:0.75, w:4.6, h:0.4, fill:{color:C.greenLt}, line:{color:C.green} });
  s.addText("✓  What this project IS", { x:5.1, y:0.75, w:4.6, h:0.4, fontSize:12, color:C.green, bold:true, valign:"middle", margin:8 });

  const isItems = [
    ["FPGA hardware accelerator", "Custom HLS kernel on Kria KV260"],
    ["Classical simulation", "Of the oracle-diffusion mathematical pattern"],
    ["Wall-clock speedup", "Through FPGA parallelism vs CPU (Qiskit)"],
    ["Novel contribution", "First FPGA implementation for 6G URLLC scheduling"],
  ];
  isItems.forEach(([title, sub], i) => {
    s.addShape(pres.shapes.RECTANGLE, { x:5.1, y:1.22+i*0.62, w:4.6, h:0.52, fill:{color:C.greenLt}, line:{color:C.border}, shadow:makeCardShadow() });
    s.addText(title, { x:5.22, y:1.22+i*0.62+0.03, w:4.3, h:0.24, fontSize:11, color:C.green, bold:true, margin:0 });
    s.addText(sub, { x:5.22, y:1.22+i*0.62+0.26, w:4.3, h:0.22, fontSize:10, color:C.muted, margin:0 });
  });

  // Bottom thesis statement
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:4.78, w:9.4, h:0.65, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText([
    {text:"Thesis statement:  ", options:{bold:true, color:C.teal}},
    {text:"We implement an FPGA accelerator using the oracle-diffusion pattern of Grover's algorithm to schedule 6G URLLC users in <500 μs, and measure how close to optimal it gets.", options:{color:C.text}},
  ], { x:0.42, y:4.78, w:9.2, h:0.65, fontSize:11.5, valign:"middle", margin:0 });
}

