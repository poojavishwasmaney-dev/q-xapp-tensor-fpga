  const fpgaSolves = [
    ["Eq 5","Amplitude BRAM init (ARM PS)"],
    ["Eq 6","Oracle sign-flip (HLS PL)"],
    ["Eq 7","Mean + diffusion (HLS PL)"],
    ["Eq 8","m iterations (HLS loop)"],
    ["—","ArgMax → best state (HLS PL)"],
    ["Eq 1+2","Rate calc (ARM PS pre-step)"],
  ];
  fpgaSolves.forEach(([eq, desc], i) => {
    s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.05+i*0.5, w:2.96, h:0.44, fill:{color:C.white}, line:{color:C.border} });
    s.addText(eq, { x:0.47, y:1.05+i*0.5, w:0.72, h:0.44, fontSize:9.5, color:C.navy, bold:true, fontFace:"Courier New", valign:"middle", margin:0 });
    s.addText(desc, { x:1.22, y:1.05+i*0.5, w:2.1, h:0.44, fontSize:9.5, color:C.text, valign:"middle", margin:0 });
  });

  // Right: HLS code
  s.addShape(pres.shapes.RECTANGLE, { x:3.65, y:0.65, w:6.05, h:3.5, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("// grover_kernel.cpp — HLS kernel (Vitis HLS)", { x:3.75, y:0.65, w:5.85, h:0.26, fontSize:8, color:"6A9955", fontFace:"Courier New", margin:0 });
  const hlsLines = [
    ["#include <ap_fixed.h>", C.white],
    ["typedef ap_fixed<16,8,AP_RND,AP_SAT> amplitude_t;", C.white],
    ["#define N_STATES 256  // 2^8 for N=8", "6A9955"],
    ["#define N_ITER   2    // m = floor(pi/4 * sqrt(256/26))", "6A9955"],
    ["", C.white],
    ["void grover_kernel(amplitude_t amps[N_STATES],", C.white],
    ["                   bool good[N_STATES],", C.white],
    ["                   int* best_idx) {", C.white],
    ["  #pragma HLS INTERFACE m_axi port=amps bundle=gmem0", "6A9955"],
    ["  #pragma HLS INTERFACE m_axi port=good bundle=gmem1", "6A9955"],
    ["  for(int iter=0; iter<N_ITER; iter++) {", C.white],
    ["    // Oracle (Eq 6) — 16x unrolled = 16 parallel ops", "6A9955"],
    ["    for(int i=0;i<N_STATES;i++){#pragma HLS UNROLL factor=16", C.white],
    ["      amps[i] = good[i] ? -amps[i] : amps[i]; }", C.white],
    ["    // Diffusion (Eq 7) — 8-stage reduction tree", "6A9955"],
    ["    amplitude_t sum=0;", C.white],
    ["    for(int i=0;i<N_STATES;i++) sum+=amps[i];", C.white],
    ["    amplitude_t mean=sum/N_STATES;", C.white],
    ["    for(int i=0;i<N_STATES;i++){#pragma HLS UNROLL factor=16", C.white],
    ["      amps[i]=(2*mean)-amps[i]; }", C.white],
    ["  }", C.white],
    ["  // ArgMax — find best schedule", "6A9955"],
    ["  *best_idx=0;", C.white],
    ["  for(int i=1;i<N_STATES;i++) if(amps[i]>amps[*best_idx]) *best_idx=i;", C.white],
    ["}", C.white],
  ];
  hlsLines.forEach(([line, col], i) => {
    s.addText(line, { x:3.75, y:0.93+i*0.126, w:5.85, h:0.126, fontSize:7.8, color:col, fontFace:"Courier New", margin:0 });
  });

  // Latency + resource table
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:4.22, w:9.4, h:1.2, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Projected performance (requires measurement — not a claim):", { x:0.42, y:4.24, w:9, h:0.26, fontSize:10.5, color:C.navy, bold:true, margin:0 });
  const perfRows = [
    [{text:"N", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Kernel compute", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"DMA+PS overhead", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"End-to-end target", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"URLLC budget", options:{bold:true,color:C.white,fill:{color:C.navy}}}],
