    s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.1+i*0.35, w:4.36, h:0.3, fill: i%2===0?C.white:C.offWht, line:{color:C.border} });
    s.addText(k, { x:0.48, y:1.1+i*0.35, w:1.1, h:0.3, fontSize:10, color:C.muted, bold:true, valign:"middle", margin:0 });
    s.addText(v, { x:1.62, y:1.1+i*0.35, w:3.1, h:0.3, fontSize:10, color:C.text, valign:"middle", margin:0 });
  });

  // Comparison table
  s.addShape(pres.shapes.RECTANGLE, { x:5.1, y:0.7, w:4.6, h:3.2, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Why KV260 vs alternatives:", { x:5.22, y:0.73, w:4.36, h:0.3, fontSize:12, color:C.navy, bold:true, margin:0 });
  const alts = [
    [{text:"Board", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"LUTs", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Price", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Verdict", options:{bold:true,color:C.white,fill:{color:C.navy}}}],
    ["Raspberry Pi 4","None","$75",{text:"No FPGA", options:{color:C.red}}],
    ["DE10-Nano","110K","$350",{text:"Fewer DSP", options:{color:C.amber}}],
    ["ZCU104","144K","$2000",{text:"Too expensive", options:{color:C.amber}}],
    [{text:"Kria KV260", options:{bold:true,color:C.teal}},"144K","$500",{text:"✓ CHOSEN", options:{color:C.green, bold:true}}],
  ];
  s.addTable(alts, {
    x:5.1, y:1.1, w:4.6, h:2.7,
    border:{pt:0.5, color:C.border}, fill:{color:C.white},
    colW:[1.6, 1.1, 0.9, 1.0],
    fontSize:10.5, fontFace:"Calibri", rowH:0.45,
  });

  // Memory adequacy
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:3.98, w:9.4, h:1.52, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("BRAM adequacy for each problem size:", { x:0.42, y:4.02, w:9.0, h:0.28, fontSize:11, color:C.navy, bold:true, margin:0 });
  const memRows = [
    [{text:"N", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"States", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Amplitudes @16-bit", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"good_state[] @1-bit", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Total BRAM", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Status", options:{bold:true,color:C.white,fill:{color:C.navy}}}],
    ["8","256","512 B","32 B","~1 KB",{text:"✓ Trivial", options:{color:C.green}}],
    ["12","4,096","8 KB","512 B","~9 KB",{text:"✓ Fine", options:{color:C.green}}],
    ["16","65,536","128 KB","8 KB","~140 KB",{text:"✓ Fits (5.1 MB avail)", options:{color:C.green}}],
    [{text:"32", options:{color:C.red}},{text:"4.3 B", options:{color:C.red}},{text:"8 GB", options:{color:C.red}},{text:"536 MB", options:{color:C.red}},{text:">>8 GB", options:{color:C.red}},{text:"✗ IMPOSSIBLE", options:{color:C.red, bold:true}}],
  ];
  s.addTable(memRows, {
    x:0.3, y:4.34, w:9.4, h:1.12,
    border:{pt:0.5, color:C.border}, fill:{color:C.white},
    colW:[0.6, 1.2, 2.0, 2.0, 1.8, 1.8],
