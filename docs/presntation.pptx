  const phases = [
    { weeks:"Wk 1–2", title:"Foundation", color:C.teal, tasks:["Literature review (Grover, O-RAN, URLLC, 3GPP TR 38.901)","Set up Qiskit ≥ 1.0 environment, install qiskit_algorithms","Implement greedy + exhaustive baseline for N=4,6,8","Define channel model (TDL-C) and Monte Carlo harness"], milestone:"Baseline scheduler working + test harness ready" },
    { weeks:"Wk 3–4", title:"Qiskit Grover", color:C.tealMid, tasks:["Implement rate + FBL (Eq 1+2) and utility (Eq 3+4)","Build oracle with greedy threshold (NOT O(2^N) enumeration)","Run Grover for N=4,6,8 over 1000 random seeds","Measure solution quality vs exhaustive and greedy"], milestone:"Algorithmic validation complete — quality metrics confirmed" },
    { weeks:"Wk 5–6", title:"FPGA Setup", color:C.navy, tasks:["Install Vitis HLS + Vivado 2023.x","Set up Kria KV260 + PYNQ Python environment","Complete Vitis HLS tutorial (matrix multiply, fixed-point)","Design AXI-DMA data transfer protocol (PS ↔ PL)"], milestone:"Toolchain verified — simple HLS kernel on board" },
    { weeks:"Wk 7–8", title:"HLS Kernel", color:C.slate, tasks:["Implement oracle step (Eq 6) — UNROLL factor=16","Implement parallel reduction tree for diffusion (Eq 7)","Implement m-iteration loop (Eq 8) with pipelining","C-simulation + RTL simulation in Vitis HLS"], milestone:"Kernel passing C-sim and RTL-sim vs Qiskit golden output" },
    { weeks:"Wk 9–10", title:"Integration & Test", color:C.green, tasks:["AXI-DMA integration (ARM PS → PL → PS)","Write PYNQ Python driver + latency instrumentation","End-to-end test: N=8,12,16 — measure all three phases","Produce Vivado resource utilisation report"], milestone:"Full system running — latency + quality data collected" },
    { weeks:"Wk 11–12", title:"Analysis & Thesis", color:C.teal, tasks:["Statistical analysis: 1000 MC drops, 95% CI, box plots","Comparison charts: FPGA vs greedy vs Qiskit-CPU","Write thesis (40+ pages) — write as you go each week!","Final presentation preparation and supervisor review"], milestone:"Thesis submitted — final presentation delivered" },
  ];

  phases.forEach(({weeks, title, color, tasks, milestone}, i) => {
    const by = 0.65 + i*0.82;
