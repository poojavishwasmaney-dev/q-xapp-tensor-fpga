{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("THE SCHEDULING PROBLEM", { x:0.4, y:0, w:9.2, h:0.55, fontSize:16, color:C.white, bold:true, valign:"middle", margin:0 });

  // Problem description box
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.7, w:9.4, h:1.0, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText([
    {text:"Core Problem:  ", options:{bold:true, color:C.navy}},
    {text:"A 6G base station must select which N users to serve across K resource blocks each scheduling interval, maximising total utility while satisfying fairness and QoS constraints — all within 500 μs.", options:{color:C.text}},
  ], { x:0.5, y:0.7, w:9.1, h:1.0, fontSize:12.5, valign:"middle", margin:0 });

  // Why hard label
