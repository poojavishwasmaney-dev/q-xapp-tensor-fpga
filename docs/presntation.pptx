  ];
  stats.forEach(([val, lbl, col], i) => {
    s.addShape(pres.shapes.RECTANGLE, { x:0.3+i*2.38, y:0.72, w:2.2, h:1.2, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
    s.addShape(pres.shapes.RECTANGLE, { x:0.3+i*2.38, y:0.72, w:2.2, h:0.06, fill:{color:col}, line:{color:col} });
    s.addText(val, { x:0.3+i*2.38, y:0.78, w:2.2, h:0.56, fontSize:26, color:col, bold:true, align:"center", valign:"middle", margin:0 });
    s.addText(lbl, { x:0.3+i*2.38, y:1.34, w:2.2, h:0.55, fontSize:9.5, color:C.muted, align:"center", valign:"top", margin:4 });
  });

  s.addText("Sources: 3GPP TR 38.824 (5G URLLC) + ITU-R M.2160 (IMT-2030 / 6G)", {
    x:0.3, y:1.98, w:9.4, h:0.25, fontSize:9, color:C.muted, margin:0
  });

  // Use cases
  s.addText("Applications that require this performance:", { x:0.3, y:2.32, w:9.4, h:0.3, fontSize:12, color:C.navy, bold:true, margin:0 });

  const cases = [
    ["🚗", "Autonomous vehicles", "Real-time coordination, collision avoidance"],
    ["🏭", "Industrial robots", "Industry 4.0 — sub-ms control loops"],
    ["🔬", "Remote surgery", "Haptic feedback, zero tolerance for delay"],
    ["🥽", "Tactile internet", "Touch and feel transmitted over network"],
    ["📡", "mmWave streaming", "High-density AR/VR at the edge"],
    ["⚡", "Smart grid control", "Power network real-time switching"],
  ];
  cases.forEach(([icon, title, desc], i) => {
    const col = i < 3 ? 0 : 1;
    const row = i % 3;
    const bx = 0.3 + col*4.85;
    const by = 2.68 + row*0.72;
    s.addShape(pres.shapes.RECTANGLE, { x:bx, y:by, w:4.65, h:0.62, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
    s.addText(icon + "  " + title, { x:bx+0.12, y:by+0.02, w:4.4, h:0.3, fontSize:12, color:C.navy, bold:true, margin:0 });
    s.addText(desc, { x:bx+0.12, y:by+0.3, w:4.4, h:0.28, fontSize:10, color:C.muted, margin:0 });
  });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 5 — PROPOSED SOLUTION OVERVIEW
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("PROPOSED SOLUTION: ORACLE-DIFFUSION FPGA ACCELERATOR", { x:0.4, y:0, w:9.2, h:0.55, fontSize:15, color:C.white, bold:true, valign:"middle", margin:0 });

  // 3-phase pipeline
  const phases = [
    { num:"1", title:"Pre-processing (ARM PS)", color:C.slate, items:["Read channel state (SINR per user/PRB)", "Compute FBL-adjusted rates", "Set oracle threshold via greedy", "Transfer data to FPGA via AXI-DMA"] },
    { num:"2", title:"Grover Kernel (FPGA PL)", color:C.teal, items:["Init uniform amplitudes α = 1/√(2^N)", "Oracle: flip phase of good states", "Diffusion: reflect around mean", "Repeat m iterations → ArgMax"] },
    { num:"3", title:"Post-processing (ARM PS)", color:C.navy, items:["Decode best schedule bitmask", "Validate QoS constraints", "Issue scheduling decision", "Send via E2 interface to O-RAN DU"] },
  ];

  phases.forEach(({num, title, color, items}, i) => {
    const bx = 0.3 + i*3.2;
    s.addShape(pres.shapes.RECTANGLE, { x:bx, y:0.65, w:3.0, h:4.55, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeShadow() });
    s.addShape(pres.shapes.RECTANGLE, { x:bx, y:0.65, w:3.0, h:0.5, fill:{color:color}, line:{color:color} });
    s.addText(`Phase ${num}`, { x:bx, y:0.65, w:3.0, h:0.22, fontSize:9.5, color:C.white, bold:true, align:"center", valign:"middle", margin:0 });
    s.addText(title, { x:bx, y:0.87, w:3.0, h:0.25, fontSize:10, color:C.white, align:"center", valign:"middle", margin:0 });
    items.forEach((it, j) => {
      s.addShape(pres.shapes.RECTANGLE, { x:bx+0.15, y:1.28+j*0.8, w:2.7, h:0.68, fill:{color:C.white}, line:{color:C.border} });
      s.addText(it, { x:bx+0.22, y:1.28+j*0.8, w:2.56, h:0.68, fontSize:10.5, color:C.text, valign:"middle", margin:0 });
    });
    // Arrow between phases
    if (i < 2) {
      s.addShape(pres.shapes.LINE, { x:3.3+i*3.2, y:2.92, w:0.2, h:0, line:{color:C.teal, width:2} });
      s.addText("▶", { x:3.3+i*3.2+0.18, y:2.78, w:0.22, h:0.28, fontSize:14, color:C.teal, margin:0 });
    }
  });

  // Bottom key claim
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:5.25, w:9.4, h:0.22, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("Key claim: FPGA parallelism achieves <500 μs end-to-end — not quantum speedup, but hardware acceleration", {
    x:0.3, y:5.25, w:9.4, h:0.22, fontSize:10, color:C.tealMid, align:"center", valign:"middle", margin:0
  });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 6 — MATHEMATICAL FOUNDATION Eq 1 & 2
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("EQUATIONS 1 & 2 — RATE CALCULATION (SOLVED IN QISKIT & FPGA)", { x:0.4, y:0, w:9.2, h:0.55, fontSize:14, color:C.white, bold:true, valign:"middle", margin:0 });

  // Badge
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.65, w:2.1, h:0.3, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText("SOLVED IN: Qiskit (Python) + FPGA pre-processing (ARM PS)", { x:0.3, y:0.65, w:9.4, h:0.3, fontSize:9.5, color:C.teal, bold:true, valign:"middle", margin:6 });

  // EQ1
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:1.05, w:4.55, h:2.7, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 1 — Achievable Rate (Finite Blocklength)", { x:0.4, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.43, w:4.3, h:0.62, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("R_ia = B_a [ log₂(1 + SINR_ia) − ζ_ia ]", { x:0.42, y:1.43, w:4.3, h:0.62, fontSize:13, color:C.codeGr, bold:true, align:"center", valign:"middle", fontFace:"Courier New", margin:0 });
  const eq1vars = [["B_a","Bandwidth of PRB a (240 kHz)"],["SINR_ia","P·|h_ia|² / σ² (signal to noise ratio)"],["ζ_ia","Finite blocklength penalty (Eq. 2)"]];
  eq1vars.forEach(([v, d], i) => {
    s.addText(v, { x:0.45, y:2.14+i*0.5, w:1.0, h:0.4, fontSize:10.5, color:C.teal, bold:true, fontFace:"Courier New", margin:0 });
    s.addText(d, { x:1.52, y:2.14+i*0.5, w:3.2, h:0.4, fontSize:10, color:C.text, valign:"middle", margin:0 });
  });

  // EQ2
  s.addShape(pres.shapes.RECTANGLE, { x:5.15, y:1.05, w:4.55, h:2.7, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 2 — Finite Blocklength Penalty", { x:5.25, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:1.43, w:4.3, h:0.62, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("ζ_ia = log₂(e) · Q⁻¹(ε) · √(η_ia / l_ia)", { x:5.27, y:1.43, w:4.3, h:0.62, fontSize:12, color:C.codeGr, bold:true, align:"center", valign:"middle", fontFace:"Courier New", margin:0 });
  const eq2vars = [["ε","Error probability = 10⁻⁵ for URLLC"],["Q⁻¹","Inverse Q-function"],["η_ia","1 − [σ²/(σ²+P|h|²)]² (dispersion)"],["l_ia","Blocklength = 32 bytes"]];
  eq2vars.forEach(([v, d], i) => {
    s.addText(v, { x:5.3, y:2.14+i*0.4, w:0.85, h:0.35, fontSize:10.5, color:C.teal, bold:true, fontFace:"Courier New", margin:0 });
    s.addText(d, { x:6.22, y:2.14+i*0.4, w:3.35, h:0.35, fontSize:10, color:C.text, valign:"middle", margin:0 });
  });

  // Source
  s.addText("Source: Polyanskiy, Poor & Verdú, IEEE Trans. Inf. Theory 2010 (finite blocklength theory)", {
    x:0.3, y:3.82, w:9.4, h:0.26, fontSize:9, color:C.muted, margin:0
  });

  // Python code
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:4.14, w:9.4, h:1.35, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("# Python (Qiskit pre-processing) — Phase 1 ARM calculation", { x:0.44, y:4.14, w:9.1, h:0.28, fontSize:9, color:"6A9955", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"def ", options:{color:"C586C0"}},{text:"calculate_rate", options:{color:"DCDCAA"}},{text:"(B, P, h, sigma2, eps, l):\n", options:{color:C.white}},
    {text:"    sinr = P * abs(h)**2 / sigma2\n", options:{color:C.white}},
    {text:"    zeta = log2(e) * qinv(eps) * sqrt((1-(sigma2/(sigma2+P*abs(h)**2))**2)/l)\n", options:{color:C.white}},
    {text:"    return ", options:{color:"C586C0"}},{text:"B * (log2(1 + sinr) - zeta)   ", options:{color:C.white}},{text:"# Eq 1 + 2", options:{color:"6A9955"}},
  ], { x:0.44, y:4.42, w:9.1, h:0.97, fontSize:9.5, fontFace:"Courier New", margin:0 });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 7 — EQUATIONS 3 & 4 UTILITY + CONSTRAINTS
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("EQUATIONS 3 & 4 — UTILITY FUNCTION & CONSTRAINTS (SOLVED IN QISKIT)", { x:0.4, y:0, w:9.2, h:0.55, fontSize:14, color:C.white, bold:true, valign:"middle", margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.65, w:9.4, h:0.3, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText("SOLVED IN: Qiskit (Python) — defines what schedule is 'good' for the oracle", { x:0.3, y:0.65, w:9.4, h:0.3, fontSize:9.5, color:C.teal, bold:true, valign:"middle", margin:6 });

  // Utility eq
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:1.05, w:4.55, h:2.25, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 3 — Proportional Fairness Utility", { x:0.4, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.42, w:4.3, h:0.55, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("U(S) = Σ_{i∈S}  w_i · log₂(1 + SINR_i)", { x:0.42, y:1.42, w:4.3, h:0.55, fontSize:12, color:C.codeGr, bold:true, align:"center", valign:"middle", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"w_i", options:{color:C.teal, bold:true}},{text:" = r_i(t) / R_i(t)   — proportional fairness weight\n", options:{color:C.text}},
    {text:"r_i(t)", options:{color:C.teal, bold:true}},{text:" = instantaneous rate;   ", options:{color:C.text}},
    {text:"R_i(t)", options:{color:C.teal, bold:true}},{text:" = moving average\n", options:{color:C.text}},
    {text:"⚠ Requires T≥500 TTI simulation — not single-shot", options:{color:C.amber, bold:true}},
  ], { x:0.42, y:2.02, w:4.3, h:1.2, fontSize:10, fontFace:"Calibri", margin:4 });

  // Constraints
  s.addShape(pres.shapes.RECTANGLE, { x:5.15, y:1.05, w:4.55, h:2.25, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 4 — Scheduling Constraints", { x:5.25, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  const constraints = [
    ["(4a)", "Σ x_ia = 1  ∀a", "One user per PRB"],
    ["(4b)", "Σ x_ia ≤ C_i  ∀i", "Fairness cap per user"],
    ["(4c)", "Σ R_ia·x_ia ≥ R_min  ∀i", "Min QoS guaranteed"],
  ];
  constraints.forEach(([label, eq, desc], i) => {
    s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:1.42+i*0.6, w:4.3, h:0.52, fill:{color:C.white}, line:{color:C.border} });
    s.addText(label, { x:5.32, y:1.42+i*0.6, w:0.5, h:0.52, fontSize:10, color:C.muted, valign:"middle", margin:0 });
    s.addText(eq, { x:5.85, y:1.42+i*0.6, w:2.1, h:0.52, fontSize:10, color:C.teal, bold:true, fontFace:"Courier New", valign:"middle", margin:0 });
    s.addText(desc, { x:8.0, y:1.42+i*0.6, w:1.48, h:0.52, fontSize:9.5, color:C.text, valign:"middle", margin:0 });
  });

  // Python code
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:3.38, w:9.4, h:2.08, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("# Qiskit Python — utility + oracle check (decides which schedules are 'good')", { x:0.44, y:3.38, w:9.1, h:0.28, fontSize:9, color:"6A9955", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"def ", options:{color:"C586C0"}},{text:"utility", options:{color:"DCDCAA"}},{text:"(self, bitstring):  ", options:{color:C.white}},{text:"# Eq. 3\n", options:{color:"6A9955"}},
    {text:"    selected = [i ", options:{color:C.white}},{text:"for ", options:{color:"C586C0"}},{text:"i,b ", options:{color:C.white}},{text:"in ", options:{color:"C586C0"}},{text:"enumerate(bitstring) ", options:{color:C.white}},{text:"if ", options:{color:"C586C0"}},{text:"b=='1']\n", options:{color:C.white}},
    {text:"    if ", options:{color:"C586C0"}},{text:"len(selected) != self.K: ", options:{color:C.white}},{text:"return ", options:{color:"C586C0"}},{text:"0  ", options:{color:C.white}},{text:"# constraint (4a)\n", options:{color:"6A9955"}},
    {text:"    return ", options:{color:"C586C0"}},{text:"sum(self.w[i]*log2(1+self.sinr[i]) ", options:{color:C.white}},{text:"for ", options:{color:"C586C0"}},{text:"i ", options:{color:C.white}},{text:"in ", options:{color:"C586C0"}},{text:"selected)\n", options:{color:C.white}},
    {text:"\ndef ", options:{color:"C586C0"}},{text:"is_good_state", options:{color:"DCDCAA"}},{text:"(self, bitstring):  ", options:{color:C.white}},{text:"# Oracle condition — NO full enumeration\n", options:{color:"6A9955"}},
    {text:"    return ", options:{color:"C586C0"}},{text:"self.utility(bitstring) >= self.greedy_threshold  ", options:{color:C.white}},{text:"# threshold set a priori", options:{color:"6A9955"}},
  ], { x:0.44, y:3.66, w:9.1, h:1.72, fontSize:9.5, fontFace:"Courier New", margin:0 });

  s.addText("Source: Kelly, Maulloo & Tan, J. Operational Research 1998 (proportional fairness)", { x:0.3, y:5.5, w:9.4, h:0.22, fontSize:9, color:C.muted, margin:0 });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 8 — QUANTUM STATE REPRESENTATION Eq 5
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("EQUATION 5 — AMPLITUDE STATE ENCODING (SOLVED IN QISKIT & FPGA)", { x:0.4, y:0, w:9.2, h:0.55, fontSize:14, color:C.white, bold:true, valign:"middle", margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.65, w:9.4, h:0.3, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText("SOLVED IN: Qiskit (statevector simulation) AND FPGA (amplitude array in BRAM)", { x:0.3, y:0.65, w:9.4, h:0.3, fontSize:9.5, color:C.teal, bold:true, valign:"middle", margin:6 });

  // Left: concept
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:1.05, w:4.6, h:3.6, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 5 — Uniform Superposition", { x:0.4, y:1.08, w:4.4, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.42, w:4.35, h:0.55, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("|Ψ⟩ = (1/√2ᴺ) · Σ |x⟩  for x = 0..2ᴺ−1", { x:0.42, y:1.42, w:4.35, h:0.55, fontSize:11.5, color:C.codeGr, bold:true, align:"center", valign:"middle", fontFace:"Courier New", margin:0 });
  s.addText("Each schedule = an N-bit binary string:", { x:0.42, y:2.06, w:4.35, h:0.28, fontSize:10.5, color:C.navy, bold:true, margin:0 });
  s.addText("N = 4 users, K = 2 to schedule\nSchedule {user1, user3} → |1010⟩\nSchedule {user2, user4} → |0101⟩", {
    x:0.42, y:2.34, w:4.35, h:0.7, fontSize:10, color:C.text, fontFace:"Courier New", margin:4
  });
  s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:3.12, w:4.35, h:1.35, fill:{color:C.goldLt}, line:{color:C.gold} });
  s.addText("⚠  IMPORTANT DISTINCTION", { x:0.52, y:3.12, w:4.15, h:0.28, fontSize:10, color:C.amber, bold:true, margin:0 });
  s.addText("In Qiskit: this is a complex number vector in RAM — a pure mathematical simulation of quantum amplitudes.\n\nOn FPGA: this is a fixed-point array in BRAM. No qubits. No superposition. Just numbers.", {
    x:0.52, y:3.4, w:4.15, h:1.0, fontSize:9.5, color:C.amber, margin:0
  });

  // Right: FPGA vs Qiskit encoding comparison
  s.addShape(pres.shapes.RECTANGLE, { x:5.15, y:1.05, w:4.55, h:3.6, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("How each platform stores amplitudes:", { x:5.25, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });

  s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:1.42, w:4.3, h:1.5, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("# Qiskit (statevector, 64-bit complex floats)", { x:5.35, y:1.42, w:4.15, h:0.24, fontSize:8.5, color:"6A9955", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"qc = QuantumCircuit(N)\n", options:{color:C.white}},
    {text:"for ", options:{color:"C586C0"}},{text:"i ", options:{color:C.white}},{text:"in ", options:{color:"C586C0"}},{text:"range(N): qc.h(i)  ", options:{color:C.white}},{text:"# Hadamard\n", options:{color:"6A9955"}},
    {text:"# result: sv[0..2^N-1] complex amplitudes", options:{color:"6A9955"}},
  ], { x:5.35, y:1.66, w:4.15, h:1.22, fontSize:9, fontFace:"Courier New", margin:0 });

  s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:3.02, w:4.3, h:1.4, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("// FPGA HLS (ap_fixed<16,8> — 16-bit fixed point)", { x:5.35, y:3.02, w:4.15, h:0.24, fontSize:8.5, color:"6A9955", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"amplitude_t amps[N_STATES];  // BRAM array\n", options:{color:C.white}},
    {text:"for(int i=0; i<N_STATES; i++)\n", options:{color:C.white}},
    {text:"    amps[i] = inv_sqrt_N;  // 1/√(2^N)\n", options:{color:C.white}},
    {text:"// Same maths, 16-bit fixed point, no qubits", options:{color:"6A9955"}},
  ], { x:5.35, y:3.26, w:4.15, h:1.12, fontSize:9, fontFace:"Courier New", margin:0 });

  s.addText("Scope: N ≤ 16 (65,536 states × 2 bytes = 128 KB — fits in KV260 BRAM)", {
    x:0.3, y:4.74, w:9.4, h:0.3, fontSize:10, color:C.green, bold:true, margin:0
  });
  s.addText("N = 32 would require 4.3B × 2 bytes = 8 GB — physically impossible on KV260 (5.1 MB BRAM).", {
    x:0.3, y:5.05, w:9.4, h:0.26, fontSize:9.5, color:C.red, margin:0
  });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 9 — ORACLE Eq 6
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("EQUATION 6 — THE ORACLE: MARKING GOOD SCHEDULES", { x:0.4, y:0, w:9.2, h:0.55, fontSize:15, color:C.white, bold:true, valign:"middle", margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.65, w:9.4, h:0.3, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText("SOLVED IN: Both — Qiskit builds oracle automatically; FPGA applies sign flip per pre-computed good_state[] array", { x:0.3, y:0.65, w:9.4, h:0.3, fontSize:9.5, color:C.teal, bold:true, valign:"middle", margin:6 });

  // Equation
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:1.05, w:4.6, h:2.55, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 6 — Phase Oracle", { x:0.4, y:1.08, w:4.4, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.42, w:4.35, h:0.52, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("O|x⟩ = (−1)^f(x) · |x⟩", { x:0.42, y:1.42, w:4.35, h:0.52, fontSize:16, color:C.codeGr, bold:true, align:"center", valign:"middle", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"f(x) = 1 ", options:{bold:true, color:C.teal}},{text:"if schedule x is GOOD, else 0\n\n", options:{color:C.text}},
    {text:"Good schedule conditions:\n", options:{bold:true, color:C.navy}},
    {text:"  • Exactly K users selected (cardinality)\n", options:{color:C.text}},
    {text:"  • U(x) ≥ threshold (greedy upper bound)\n", options:{color:C.text}},
    {text:"  • All SINR_i ≥ γ_min (QoS floor)", options:{color:C.text}},
  ], { x:0.42, y:2.02, w:4.35, h:1.5, fontSize:10.5, margin:4 });

  // Critical note
  s.addShape(pres.shapes.RECTANGLE, { x:5.15, y:1.05, w:4.55, h:2.55, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("FPGA Oracle implementation", { x:5.25, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:1.42, w:4.3, h:1.62, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText([
    {text:"// good_state[] pre-computed by ARM PS (greedy)\n", options:{color:"6A9955"}},
    {text:"void ", options:{color:"C586C0"}},{text:"oracle_step(amplitude_t amps[], bool good[]) {\n", options:{color:C.white}},
    {text:"  #pragma HLS PIPELINE\n", options:{color:"6A9955"}},
    {text:"  for(int i=0; i<N_STATES; i++) {\n", options:{color:C.white}},
    {text:"    #pragma HLS UNROLL factor=16\n", options:{color:"6A9955"}},
    {text:"    amps[i] = good[i] ? -amps[i] : amps[i];\n", options:{color:C.white}},
    {text:"  }\n", options:{color:C.white}},
    {text:"}", options:{color:C.white}},
  ], { x:5.3, y:1.42, w:4.25, h:1.62, fontSize:8.5, fontFace:"Courier New", margin:4 });
  s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:3.1, w:4.3, h:0.42, fill:{color:C.goldLt}, line:{color:C.gold} });
  s.addText("Threshold set by greedy (O(N log N)) — not O(2^N) enumeration", { x:5.3, y:3.1, w:4.2, h:0.42, fontSize:9.5, color:C.amber, bold:true, valign:"middle", margin:4 });

  // N=3 example
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:3.68, w:9.4, h:1.68, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Example — N=3 users, K=2 to select:", { x:0.42, y:3.71, w:9.1, h:0.28, fontSize:11, color:C.navy, bold:true, margin:0 });
  const exRows = [
    [{text:"Schedule", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Utility", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"K=2?", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Oracle action", options:{bold:true,color:C.white,fill:{color:C.navy}}},{text:"Result", options:{bold:true,color:C.white,fill:{color:C.navy}}}],
    ["|110⟩","10.5","✓ Yes",{text:"Phase flip × −1", options:{color:C.green}},{text:"Amplitude −α", options:{color:C.green}}],
    ["|101⟩","8.2","✓ Yes",{text:"Phase flip × −1", options:{color:C.green}},{text:"Amplitude −α", options:{color:C.green}}],
    ["|011⟩","3.1 (below threshold)","✓ Yes",{text:"No change", options:{color:C.red}},{text:"Amplitude +α", options:{color:C.red}}],
    ["|100⟩","—","✗ Only 1 user",{text:"No change", options:{color:C.red}},{text:"Amplitude +α", options:{color:C.red}}],
  ];
  s.addTable(exRows, {
    x:0.3, y:4.0, w:9.4, h:1.3,
    border:{pt:0.5, color:C.border},
    fill:{color:C.white},
    colW:[1.5, 2.5, 1.4, 2.2, 1.8],
    fontSize:10, fontFace:"Calibri", rowH:0.26,
  });
}

// ═══════════════════════════════════════════════════════════
// SLIDE 10 — DIFFUSION OPERATOR Eq 7
// ═══════════════════════════════════════════════════════════
{
  let s = pres.addSlide();
  s.background = { color: C.white };
  s.addShape(pres.shapes.RECTANGLE, { x:0, y:0, w:10, h:0.55, fill:{color:C.navy}, line:{color:C.navy} });
  s.addText("EQUATION 7 — DIFFUSION OPERATOR: AMPLIFYING GOOD SCHEDULES", { x:0.4, y:0, w:9.2, h:0.55, fontSize:14, color:C.white, bold:true, valign:"middle", margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:0.65, w:9.4, h:0.3, fill:{color:C.tealLt}, line:{color:C.teal} });
  s.addText("SOLVED IN: Qiskit (automatic) + FPGA HLS kernel (explicit parallel implementation)", { x:0.3, y:0.65, w:9.4, h:0.3, fontSize:9.5, color:C.teal, bold:true, valign:"middle", margin:6 });

  // Equation left
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:1.05, w:4.6, h:2.12, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 7 — Grover Diffusion Operator", { x:0.4, y:1.08, w:4.4, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:0.42, y:1.42, w:4.35, h:0.5, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText("D = 2|Ψ⟩⟨Ψ| − I", { x:0.42, y:1.42, w:4.35, h:0.5, fontSize:18, color:C.codeGr, bold:true, align:"center", valign:"middle", fontFace:"Courier New", margin:0 });
  s.addText([
    {text:"Effect:\n", options:{bold:true, color:C.navy}},
    {text:"  • Reflects amplitude vector around the mean\n", options:{color:C.text}},
    {text:"  • Marked states: amplitude increases\n", options:{color:C.green}},
    {text:"  • Unmarked states: amplitude decreases\n", options:{color:C.red}},
    {text:"  • One iteration: |Ψ_{k+1}⟩ = D · O · |Ψ_k⟩", options:{color:C.text}},
  ], { x:0.42, y:2.0, w:4.35, h:1.1, fontSize:10.5, margin:4 });

  // HLS code right
  s.addShape(pres.shapes.RECTANGLE, { x:5.15, y:1.05, w:4.55, h:2.12, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("FPGA HLS diffusion kernel (grover_kernel.cpp):", { x:5.25, y:1.08, w:4.35, h:0.3, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:5.27, y:1.42, w:4.3, h:1.72, fill:{color:C.codeBg}, line:{color:C.codeBg} });
  s.addText([
    {text:"void ", options:{color:"C586C0"}},{text:"diffusion_step(amplitude_t amps[N_STATES]) {\n", options:{color:C.white}},
    {text:"  #pragma HLS PIPELINE\n", options:{color:"6A9955"}},
    {text:"  amplitude_t sum=0;\n", options:{color:C.white}},
    {text:"  for(int i=0;i<N_STATES;i++) sum+=amps[i]; // tree\n", options:{color:C.white}},
    {text:"  amplitude_t mean = sum / N_STATES;\n", options:{color:C.white}},
    {text:"  for(int i=0;i<N_STATES;i++) {\n", options:{color:C.white}},
    {text:"    #pragma HLS UNROLL factor=16\n", options:{color:"6A9955"}},
    {text:"    amps[i] = (2*mean) - amps[i];\n", options:{color:C.white}},
    {text:"  }\n}\n", options:{color:C.white}},
    {text:"// 8-stage parallel reduction tree for sum", options:{color:"6A9955"}},
  ], { x:5.3, y:1.42, w:4.25, h:1.72, fontSize:8.5, fontFace:"Courier New", margin:4 });

  // Iteration count
  s.addShape(pres.shapes.RECTANGLE, { x:0.3, y:3.25, w:9.4, h:2.15, fill:{color:C.slateXlt}, line:{color:C.border}, shadow:makeCardShadow() });
  s.addText("Eq. 8 — Optimal iteration count:", { x:0.42, y:3.28, w:5, h:0.28, fontSize:11, color:C.navy, bold:true, margin:0 });
  s.addShape(pres.shapes.RECTANGLE, { x:5.5, y:3.28, w:3.9, h:0.28, fill:{color:C.tealLt}, line:{color:C.teal} });
